<?xml version="1.0" encoding="UTF-8"?>
<window>
  <visible>Window.IsActive(fullscreenvideo) | Window.IsActive(visualisation)</visible>
  <visible>![Window.IsActive(sliderdialog) | Window.IsActive(pvrosdchannels) | Window.IsActive(pvrchannelguide) | Window.IsActive(pvrguideinfo) | Window.IsActive(1110)]</visible>
  <visible>Player.Seeking | Player.HasPerformedSeek(3) | [Player.Paused + !Player.Caching] | Player.Forwarding | Player.Rewinding | Player.ShowTime | Window.IsActive(videoosd) | !String.IsEmpty(Player.SeekNumeric) | !String.IsEmpty(PVR.ChannelNumberInput)</visible>
  <depth>DepthOSD</depth>
  <zorder>0</zorder>
  <controls>
    <include>PVRChannelNumberInput</include>

    <!-- Floating seek bar — only shown when the full button OSD is closed,
         so seeking is always visible even with VideoOSD.xml hidden. Mirrors
         VideoOSD's seekbar rect exactly (left=48, width=1824, bar top=968)
         so there's no visual jump when the full OSD opens/closes. -->
    <control type="group">
      <visible>!Window.IsVisible(videoosd)</visible>
      <animation effect="fade" time="200">VisibleChange</animation>
      <include>Animation_BottomSlide</include>
      <left>48</left>
      <top>900</top>
      <width>1824</width>
      <height>90</height>

      <!-- Current position / total duration — swaps to the script-driven
           scrub preview label while a scrub gesture is in progress (see
           resources/scripts/scrub_seek.py). -->
      <control type="label">
        <left>0</left><top>0</top><width>1824</width><height>28</height>
        <align>center</align>
        <font>HBM_Body_M</font>
        <textcolor>FFFFFFFF</textcolor>
        <shadowcolor>CC000000</shadowcolor>
        <label>$INFO[Player.Time] / $INFO[Player.Duration]</label>
        <visible>!String.IsEqual(Skin.String(HBM.Scrubbing),1)</visible>
      </control>
      <control type="label">
        <left>0</left><top>0</top><width>1824</width><height>28</height>
        <align>center</align>
        <font>HBM_Body_M</font>
        <textcolor>FFFFFFFF</textcolor>
        <shadowcolor>CC000000</shadowcolor>
        <label>$INFO[Skin.String(HBM.ScrubTimeLabel)]</label>
        <visible>String.IsEqual(Skin.String(HBM.Scrubbing),1)</visible>
      </control>

      <!-- Progress bar — identical visual treatment to VideoOSD's seekbar:
           30%-opacity white track, solid white played fill, same 6px height.
           Two stacked controls: live player position normally, and a
           script-driven preview percentage while scrubbing. This is what
           makes holding left/right glide smoothly instead of hard-seeking
           on every press — the real seek only commits once presses stop
           (see resources/scripts/scrub_seek.py + scrub_commit.py, wired via
           the keymap override installed by install_scrub_keymap.py). -->
      <control type="progress">
        <left>0</left><top>68</top><width>1824</width><height>6</height>
        <info>Player.Progress</info>
        <texturebg colordiffuse="4DFFFFFF">white.png</texturebg>
        <midtexture colordiffuse="FFFFFFFF">white.png</midtexture>
        <visible>!String.IsEqual(Skin.String(HBM.Scrubbing),1)</visible>
      </control>
      <control type="progress">
        <left>0</left><top>68</top><width>1824</width><height>6</height>
        <value>$INFO[Skin.String(HBM.ScrubPercent)]</value>
        <texturebg colordiffuse="4DFFFFFF">white.png</texturebg>
        <midtexture colordiffuse="FFFFFFFF">white.png</midtexture>
        <visible>String.IsEqual(Skin.String(HBM.Scrubbing),1)</visible>
      </control>
    </control>
  </controls>
</window>
