<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol>9000</defaultcontrol>
  <controls>
    <control type="image">
      <left>0</left>
      <top>0</top>
      <width>1920</width>
      <height>1080</height>
      <texture colordiffuse="8F000000">white.png</texture>
    </control>

    <control type="group">
      <centerleft>50%</centerleft>
      <centertop>50%</centertop>
      <width>620</width>
      <height>720</height>

      <control type="image">
        <left>-6</left>
        <top>-6</top>
        <width>632</width>
        <height>732</height>
        <texture border="24" colordiffuse="16000000">special://skin/media/panel_rounded.png</texture>
      </control>

      <control type="image">
        <width>620</width>
        <height>720</height>
        <texture border="24" colordiffuse="F1272A30">special://skin/media/panel_rounded.png</texture>
      </control>

      <control type="label" id="2">
        <left>40</left>
        <top>30</top>
        <width>540</width>
        <height>46</height>
        <label>Power Menu</label>
        <font>HBM_Display_M</font>
        <textcolor>TextPrimary</textcolor>
        <align>center</align>
      </control>

      <control type="image">
        <left>40</left>
        <top>92</top>
        <width>540</width>
        <height>1</height>
        <texture colordiffuse="20FFFFFF">white.png</texture>
      </control>

      <control type="panel" id="9000">
        <left>50</left>
        <top>112</top>
        <width>520</width>
        <height>568</height>
        <onup>9000</onup>
        <ondown>9000</ondown>
        <itemlayout width="520" height="68">
          <control type="image">
            <left>0</left>
            <top>67</top>
            <width>520</width>
            <height>1</height>
            <texture colordiffuse="16FFFFFF">white.png</texture>
          </control>
          <control type="label">
            <width>520</width>
            <height>68</height>
            <font>HBM_Body_M</font>
            <textcolor>TextSecondary</textcolor>
            <align>center</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label]</label>
          </control>
        </itemlayout>
        <focusedlayout width="520" height="68">
          <control type="image">
            <width>520</width>
            <height>68</height>
            <texture colordiffuse="FocusFill">white.png</texture>
          </control>
          <control type="image">
            <left>0</left>
            <top>67</top>
            <width>520</width>
            <height>1</height>
            <texture colordiffuse="16FFFFFF">white.png</texture>
          </control>
          <control type="label">
            <width>520</width>
            <height>68</height>
            <font>HBM_Body_M</font>
            <textcolor>TextPrimary</textcolor>
            <align>center</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label]</label>
          </control>
        </focusedlayout>
        <content>
          <item>
            <label>Exit</label>
            <onclick>Quit()</onclick>
            <visible>System.ShowExitButton</visible>
          </item>
          <item>
            <label>Power Off</label>
            <onclick>Powerdown()</onclick>
            <visible>System.CanPowerDown</visible>
          </item>
          <item>
            <label>Suspend</label>
            <onclick>Suspend()</onclick>
            <visible>System.CanSuspend</visible>
          </item>
          <item>
            <label>Hibernate</label>
            <onclick>Hibernate()</onclick>
            <visible>System.CanHibernate</visible>
          </item>
          <item>
            <label>Restart</label>
            <onclick>Reset()</onclick>
            <visible>System.CanReboot</visible>
          </item>
          <item>
            <label>Log Off</label>
            <onclick>System.LogOff</onclick>
            <visible>System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)</visible>
            <visible>System.Loggedon</visible>
          </item>
        </content>
      </control>
    </control>
  </controls>
</window>
