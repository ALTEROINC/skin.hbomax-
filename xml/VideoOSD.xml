      <onclick>ActivateWindow(osdsubtitlesettings)</onclick>
      <onup>200</onup>
      <onleft>605</onleft>
      <onright>607</onright>
    </control>

    <!-- Fullscreen button -->
    <control type="button" id="607">
      <left>1840</left><top>996</top><width>44</width><height>44</height>
      <texturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_fullscreen.png</texturefocus>
      <texturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_fullscreen.png</texturenofocus>
      <label/><font/>
      <onclick>Action(FullScreen)</onclick>
      <onup>200</onup>
      <onleft>606</onleft>
      <onright>608</onright>
    </control>

    <!-- ═══ EPISODES TRAY ═══ -->
