        <onclick>SetFocus(608)</onclick>
        <onup>87</onup>
        <onleft>802</onleft>
        <onright>801</onright>
        <ondown>800</ondown>
      </control>

      <!-- ─── Episodes panel (id=800) ─── -->
      <control type="panel" id="800">
        <left>48</left><top>660</top><width>1824</width><height>390</height>
        <orientation>horizontal</orientation>
        <scrolltime tween="cubic" easing="out">300</scrolltime>
        <preloaditems>2</preloaditems>
        <onclick>Action(Info)</onclick>
        <onup>801</onup>
        <onleft>800</onleft>
        <onright>800</onright>
        <visible>String.IsEqual(Skin.String(HBM.OSDEpisodesTab),episodes)</visible>
        <content target="videos" limit="30">plugin://plugin.video.themoviedb.helper/?info=episodes&amp;tmdb_type=tv&amp;tmdb_id=$INFO[VideoPlayer.UniqueID(tmdb)]&amp;season=$INFO[VideoPlayer.Season]</content>

        <!-- Unfocused card: thumbnail + text below -->
        <itemlayout width="436" height="390">
          <!-- Thumbnail placeholder bg -->
          <control type="image">
            <left>0</left><top>0</top><width>420</width><height>236</height>
            <aspectratio>stretch</aspectratio>
            <texture colordiffuse="33161C24">white.png</texture>
          </control>
          <!-- Landscape art -->
          <control type="image">
            <left>0</left><top>0</top><width>420</width><height>236</height>
            <aspectratio>scale</aspectratio>
            <texture>$INFO[ListItem.Art(landscape)]</texture>
          </control>
          <control type="image">
            <left>0</left><top>0</top><width>420</width><height>236</height>
            <aspectratio>scale</aspectratio>
            <texture>$INFO[ListItem.Art(thumb)]</texture>
          </control>
          <!-- Episode number + title -->
          <control type="label">
            <left>0</left><top>244</top><width>420</width><height>32</height>
            <font>HBM_Body_M</font>
            <textcolor>DDFFFFFF</textcolor>
            <label>E$INFO[ListItem.Episode] · $INFO[ListItem.Title]</label>
            <scroll>false</scroll>
          </control>
          <!-- Metadata: rating · duration · year -->
          <control type="label">
            <left>0</left><top>278</top><width>420</width><height>28</height>
            <font>HBM_Meta_S</font>
            <textcolor>80FFFFFF</textcolor>
            <label>$INFO[ListItem.mpaa] · $INFO[ListItem.Duration(m)] min · $INFO[ListItem.Year]</label>
          </control>
          <!-- Description (2 lines) -->
          <control type="label">
            <left>0</left><top>308</top><width>420</width><height>52</height>
            <font>HBM_Meta_S</font>
            <textcolor>66FFFFFF</textcolor>
            <label>$INFO[ListItem.Plot]</label>
            <scroll>false</scroll>
            <wrapmultiline>true</wrapmultiline>
          </control>
        </itemlayout>

        <!-- Focused card: white border + full-brightness text -->
