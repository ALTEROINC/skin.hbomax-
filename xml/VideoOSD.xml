      <visible>String.IsEqual(Skin.String(HBM.OSDEpisodesOpen),1)</visible>
      <animation effect="slide" start="0,500" end="0,0" time="350" tween="cubic" easing="out">Visible</animation>
      <animation effect="slide" start="0,0" end="0,500" time="250" tween="cubic" easing="in">Hidden</animation>

      <!-- Solid dark base — same treatment as side rail, no feathering -->
