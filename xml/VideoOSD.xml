          <left>0</left><top>0</top><width>148</width><height>40</height>
          <texturefocus border="20" colordiffuse="22FFFFFF">special://skin/media/panel_rounded.png</texturefocus>
          <texturenofocus />
          <font>HBM_Body_M</font>
          <textcolor>AAFFFFFF</textcolor>
          <focusedcolor>FFFFFFFF</focusedcolor>
          <align>center</align><aligny>center</aligny>
          <label>Episodes</label>
          <onclick>Skin.SetString(HBM.OSDEpisodesTab,episodes)</onclick>
          <onclick>SetFocus(800)</onclick>
          <onup>87</onup>
          <onleft>803</onleft>
          <onright>802</onright>
          <ondown>800</ondown>
        </control>
        <!-- Active pill overlay — white bg + dark label, shown when selected and not focused -->
        <control type="image">
          <left>0</left><top>0</top><width>148</width><height>40</height>
          <texture border="20" colordiffuse="FFFFFFFF">special://skin/media/panel_rounded.png</texture>
          <visible>String.IsEqual(Skin.String(HBM.OSDEpisodesTab),episodes) + !Control.HasFocus(801)</visible>
        </control>
        <control type="label">
          <left>0</left><top>0</top><width>148</width><height>40</height>
          <font>HBM_Body_M</font>
          <textcolor>FF101010</textcolor>
          <align>center</align><aligny>center</aligny>
          <label>Episodes</label>
          <visible>String.IsEqual(Skin.String(HBM.OSDEpisodesTab),episodes) + !Control.HasFocus(801)</visible>
        </control>
      </control>

      <!-- "You May Also Like" pill tab (id=802) -->
      <control type="group">
        <left>212</left><top>600</top>
        <control type="button" id="802">
          <left>0</left><top>0</top><width>224</width><height>40</height>
