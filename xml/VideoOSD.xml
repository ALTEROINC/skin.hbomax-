        <left>0</left><top>560</top><width>1920</width><height>520</height>
        <aspectratio>stretch</aspectratio>
        <texture colordiffuse="E0000000">white.png</texture>
      </control>
      <!-- Smoke noise overlay -->
      <control type="image">
        <left>0</left><top>560</top><width>1920</width><height>520</height>
        <aspectratio>stretch</aspectratio>
        <texture colordiffuse="40FFFFFF">special://skin/media/overlays/rail_expanded_smoke.png</texture>
      </control>

      <!-- ─── Tab row ─── -->

      <!-- "Episodes" pill tab (id=801) -->
