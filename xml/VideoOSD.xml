<?xml version="1.0" encoding="utf-8"?>
<window>
    <defaultcontrol always="true">724</defaultcontrol>
    <onback>PreviousMenu</onback>

    <controls>
        <control type="group">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>120</height>
            <visible>Player.ShowInfo + (!System.IdleTime(4) | Player.Paused)</visible>
            <animation effect="fade" start="0" end="100" time="200" tween="sine">Visible</animation>
            <animation effect="fade" start="100" end="0" time="500" tween="sine">Hidden</animation>

            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>120</height>
                <texture>special://skin/media/hbomax/osd-top-gradient.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="image" id="700">
                <left>80</left>
                <top>20</top>
                <width>300</width>
                <height>80</height>
                <texture background="true">$INFO[ListItem.Art(clearlogo)]</texture>
                <aspectratio>keep</aspectratio>
                <visible>!String.IsEmpty(ListItem.Art(clearlogo))</visible>
            </control>

            <control type="label" id="701">
                <left>80</left>
                <top>28</top>
                <width>560</width>
                <height>40</height>
                <font>SectionHeader</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>$INFO[VideoPlayer.Title]</label>
                <visible>String.IsEmpty(ListItem.Art(clearlogo))</visible>
            </control>

            <control type="label" id="702">
                <left>80</left>
                <top>76</top>
                <width>720</width>
                <height>24</height>
                <font>MetadataInfo</font>
                <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                <label>S$INFO[VideoPlayer.Season]E$INFO[VideoPlayer.Episode] · $INFO[VideoPlayer.EpisodeName]</label>
                <visible>VideoPlayer.Content(episodes)</visible>
            </control>

            <control type="label" id="703">
                <left>1640</left>
                <top>36</top>
                <width>200</width>
                <height>40</height>
                <font>ClockDisplay</font>
                <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                <align>right</align>
                <aligny>center</aligny>
                <label>$INFO[System.Time]</label>
                <visible>Skin.HasSetting(ShowClockInNav)</visible>
            </control>
        </control>

        <control type="group">
            <left>0</left>
            <top>760</top>
            <width>1920</width>
            <height>320</height>
            <visible>!System.IdleTime(4) | Player.Paused</visible>
            <animation effect="fade" start="0" end="100" time="200" tween="sine">Visible</animation>
            <animation effect="fade" start="100" end="0" time="500" tween="sine">Hidden</animation>

            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>320</height>
                <texture>special://skin/media/hbomax/hero-gradient.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="label" id="710">
                <left>80</left>
                <top>40</top>
                <width>120</width>
                <height>28</height>
                <font>MetadataInfo</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>$INFO[Player.Time]</label>
            </control>

            <control type="label" id="711">
                <left>1720</left>
                <top>40</top>
                <width>120</width>
                <height>28</height>
                <font>MetadataInfo</font>
                <textcolor>$INFO[Skin.String(ColorTextMuted)]</textcolor>
                <align>right</align>
                <label>-$INFO[Player.TimeRemaining]</label>
            </control>

            <control type="sliderex" id="712">
                <left>220</left>
                <top>57</top>
                <width>1480</width>
                <height>20</height>
                <info>Player.Progress</info>
                <texturesliderbar>white.png</texturesliderbar>
                <texturesliderbarfocus>white.png</texturesliderbarfocus>
                <textureslidernib>special://skin/media/hbomax/osd-scrubber.png</textureslidernib>
                <textureslidernibfocus>special://skin/media/hbomax/osd-scrubber.png</textureslidernibfocus>
                <colordiffuse>$INFO[Skin.String(ColorProgressBg)]</colordiffuse>
                <onup>724</onup>
                <ondown>724</ondown>
            </control>

            <control type="image" id="713">
                <left>220</left>
                <top>57</top>
                <width>1480</width>
                <height>6</height>
                <texture colordiffuse="$INFO[Skin.String(ColorProgressBg)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="image" id="714">
                <left>220</left>
                <top>57</top>
                <width>740</width>
                <height>6</height>
                <texture colordiffuse="$INFO[Skin.String(ColorTextMuted)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="image" id="715">
                <left>220</left>
                <top>57</top>
                <width>740</width>
                <height>6</height>
                <texture colordiffuse="$INFO[Skin.String(ColorProgressFill)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="group" id="716">
                <left>220</left>
                <top>49</top>
                <width>1480</width>
                <height>20</height>
                <visible>Player.ChapterCount</visible>

                <control type="image">
                    <left>370</left>
                    <top>0</top>
                    <width>2</width>
                    <height>20</height>
                    <texture colordiffuse="$INFO[Skin.String(ColorTextMuted)]">white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <control type="image">
                    <left>740</left>
                    <top>0</top>
                    <width>2</width>
                    <height>20</height>
                    <texture colordiffuse="$INFO[Skin.String(ColorTextMuted)]">white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <control type="image">
                    <left>1110</left>
                    <top>0</top>
                    <width>2</width>
                    <height>20</height>
                    <texture colordiffuse="$INFO[Skin.String(ColorTextMuted)]">white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>
            </control>

            <control type="grouplist">
                <left>676</left>
                <top>104</top>
                <width>568</width>
                <height>72</height>
                <itemgap>40</itemgap>
                <orientation>horizontal</orientation>

                <control type="group" id="720">
                    <width>48</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="720" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/previous.png" />
                        <param name="Action" value="PlayerControl(SkipPrevious)" />
                        <param name="Tooltip" value="Previous" />
                        <param name="Width" value="48" />
                        <param name="Height" value="48" />
                        <param name="IconSize" value="24" />
                    </include>
                </control>

                <control type="group" id="722">
                    <width>48</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="722" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/rewind.png" />
                        <param name="Action" value="PlayerControl(BigSkipBackward)" />
                        <param name="Tooltip" value="Back 10s" />
                        <param name="Width" value="48" />
                        <param name="Height" value="48" />
                        <param name="IconSize" value="24" />
                    </include>
                </control>

                <control type="group" id="724">
                    <width>72</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="724" />
                        <param name="Icon" value="" />
                        <param name="Action" value="PlayerControl(Play)" />
                        <param name="Tooltip" value="Play" />
                        <param name="Width" value="72" />
                        <param name="Height" value="72" />
                        <param name="IconSize" value="32" />
                    </include>
                    <control type="image">
                        <left>20</left>
                        <top>20</top>
                        <width>32</width>
                        <height>32</height>
                        <texture>special://skin/media/hbomax/icons/play.png</texture>
                        <aspectratio>keep</aspectratio>
                        <visible>Player.Paused</visible>
                    </control>
                    <control type="image">
                        <left>20</left>
                        <top>20</top>
                        <width>32</width>
                        <height>32</height>
                        <texture>special://skin/media/hbomax/icons/pause.png</texture>
                        <aspectratio>keep</aspectratio>
                        <visible>!Player.Paused</visible>
                    </control>
                </control>

                <control type="group" id="726">
                    <width>48</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="726" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/forward.png" />
                        <param name="Action" value="PlayerControl(BigSkipForward)" />
                        <param name="Tooltip" value="Skip 10s" />
                        <param name="Width" value="48" />
                        <param name="Height" value="48" />
                        <param name="IconSize" value="24" />
                    </include>
                </control>

                <control type="group" id="728">
                    <width>48</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="728" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/next.png" />
                        <param name="Action" value="PlayerControl(SkipNext)" />
                        <param name="Tooltip" value="Next" />
                        <param name="Width" value="48" />
                        <param name="Height" value="48" />
                        <param name="IconSize" value="24" />
                    </include>
                </control>
            </control>

            <control type="grouplist">
                <left>80</left>
                <top>184</top>
                <width>700</width>
                <height>56</height>
                <itemgap>24</itemgap>
                <orientation>horizontal</orientation>

                <control type="group" id="730">
                    <width>40</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="730" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/volume.png" />
                        <param name="Action" value="PlayerControl(VolumeUp)" />
                        <param name="Tooltip" value="Volume" />
                        <param name="Width" value="40" />
                        <param name="Height" value="40" />
                        <param name="IconSize" value="20" />
                    </include>
                </control>

                <control type="group" id="731">
                    <width>40</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="731" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/subtitles.png" />
                        <param name="Action" value="ActivateWindow(DialogSubtitles)" />
                        <param name="Tooltip" value="Subtitles" />
                        <param name="Width" value="40" />
                        <param name="Height" value="40" />
                        <param name="IconSize" value="20" />
                    </include>
                </control>

                <control type="group" id="732">
                    <width>40</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="732" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/audio.png" />
                        <param name="Action" value="ActivateWindow(DialogAudioDSP)" />
                        <param name="Tooltip" value="Audio" />
                        <param name="Width" value="40" />
                        <param name="Height" value="40" />
                        <param name="IconSize" value="20" />
                    </include>
                </control>

                <control type="group" id="733">
                    <width>40</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="733" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/settings.png" />
                        <param name="Action" value="ActivateWindow(DialogPlayerProcessInfo)" />
                        <param name="Tooltip" value="Settings" />
                        <param name="Width" value="40" />
                        <param name="Height" value="40" />
                        <param name="IconSize" value="20" />
                    </include>
                </control>

                <control type="group" id="734">
                    <width>40</width>
                    <height>78</height>
                    <include content="ButtonIcon">
                        <param name="ControlId" value="734" />
                        <param name="Icon" value="special://skin/media/hbomax/icons/info.png" />
                        <param name="Action" value="Action(Info)" />
                        <param name="Tooltip" value="Fullscreen Info" />
                        <param name="Width" value="40" />
                        <param name="Height" value="40" />
                        <param name="IconSize" value="20" />
                    </include>
                </control>
            </control>
        </control>

        <control type="group" id="740">
            <left>1440</left>
            <top>800</top>
            <width>400</width>
            <height>200</height>
            <visible>!String.IsEmpty(VideoPlayer.NextTitle) + Integer.IsLess(VideoPlayer.TimeRemaining,30)</visible>
            <animation effect="slide" start="80,0" end="0,0" time="400" tween="back" easing="out">Visible</animation>

            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>400</width>
                <height>200</height>
                <texture colordiffuse="$INFO[Skin.String(ColorElevated)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="label">
                <left>24</left>
                <top>20</top>
                <width>120</width>
                <height>20</height>
                <font>Badge</font>
                <textcolor>$INFO[Skin.String(ColorTextMuted)]</textcolor>
                <label>Next Episode</label>
            </control>

            <control type="image">
                <left>24</left>
                <top>56</top>
                <width>160</width>
                <height>90</height>
                <texture background="true">$INFO[VideoPlayer.NextThumb]</texture>
                <aspectratio>scale</aspectratio>
            </control>

            <control type="label">
                <left>200</left>
                <top>56</top>
                <width>176</width>
                <height>44</height>
                <font>CardLabel</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>$INFO[VideoPlayer.NextTitle]</label>
            </control>

            <control type="group" id="741">
                <left>200</left>
                <top>116</top>
                <width>160</width>
                <height>56</height>
                <include content="ButtonPrimary">
                    <param name="ControlId" value="741" />
                    <param name="Label" value="Play Next" />
                    <param name="Icon" value="" />
                    <param name="Action" value="PlayerControl(SkipNext)" />
                </include>
            </control>

            <control type="image">
                <left>0</left>
                <top>196</top>
                <width>400</width>
                <height>4</height>
                <texture colordiffuse="$INFO[Skin.String(ColorProgressBg)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="image">
                <left>0</left>
                <top>196</top>
                <width>200</width>
                <height>4</height>
                <texture colordiffuse="$INFO[Skin.String(ColorProgressFill)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>
        </control>

        <control type="subtitles">
            <left>160</left>
            <top>780</top>
            <width>1600</width>
            <height>120</height>
            <visible>!System.IdleTime(4) | Player.Paused</visible>
        </control>

        <control type="subtitles">
            <left>160</left>
            <top>980</top>
            <width>1600</width>
            <height>80</height>
            <visible>System.IdleTime(4) + !Player.Paused</visible>
        </control>
        <include condition="Skin.HasSetting(DebugOverlay)">DebugOverlay</include>
    </controls>
</window>
