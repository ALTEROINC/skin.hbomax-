<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">602</defaultcontrol>
  <onload>SetFocus(602)</onload>
  <onload condition="Player.Forwarding | Player.Rewinding">PlayerControl(Play)</onload>
  <onunload>Skin.SetString(HBM.OSDEpisodesOpen,0)</onunload>
  <onunload>Skin.SetString(HBM.OSDEpisodesTab,)</onunload>
  <animation effect="fade" start="0" end="100" time="200" type="WindowOpen"/>
  <animation effect="fade" start="100" end="0" time="200" type="WindowClose"/>
  <controls>

    <!-- Background dismiss button — all D-pad directions redirect to play button -->
    <control type="button">
      <left>0</left><top>0</top><width>1920</width><bottom>200</bottom>
      <texturefocus /><texturenofocus />
      <label/><font/>
      <onclick>Action(Close)</onclick>
      <onup>602</onup><ondown>602</ondown><onleft>602</onleft><onright>602</onright>
    </control>

    <!-- Top smoke gradient -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>160</height>
      <aspectratio>stretch</aspectratio>
      <texture colordiffuse="CC000000">special://skin/media/overlays/header_smoke.png</texture>
    </control>
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>160</height>
      <aspectratio>stretch</aspectratio>
      <texture colordiffuse="40FFFFFF">special://skin/media/overlays/rail_expanded_smoke.png</texture>
    </control>

    <!-- Bottom gradient -->
    <control type="image">
      <left>0</left><top>760</top><width>1920</width><height>320</height>
      <texture>special://skin/media/overlays/lower_browse_fade.png</texture>
    </control>

    <!-- Back / stop button -->
    <control type="button" id="600">
      <left>40</left><top>28</top><width>44</width><height>44</height>
      <texturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_back.png</texturefocus>
      <texturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_back.png</texturenofocus>
      <label/><font/>
      <onclick>Action(Stop)</onclick>
      <onup>602</onup>
      <ondown>200</ondown>
      <onleft>607</onleft>
      <onright>605</onright>
    </control>

    <!-- Rating badge -->
    <control type="group">
      <left>112</left><top>32</top>
      <visible>!String.IsEmpty(VideoPlayer.mpaa)</visible>
      <control type="image">
        <left>0</left><top>0</top><width>80</width><height>28</height>
        <texture colordiffuse="33FFFFFF">special://skin/media/panel_rect.png</texture>
      </control>
      <control type="label">
        <left>0</left><top>0</top><width>80</width><height>28</height>
        <font>HBM_Meta_S</font>
        <textcolor>FFFFFFFF</textcolor>
        <align>center</align><aligny>center</aligny>
        <label>$INFO[VideoPlayer.mpaa]</label>
      </control>
    </control>

    <!-- TV show title -->
    <control type="label">
      <left>48</left><top>876</top><width>1400</width><height>48</height>
      <font>HBM_Title_M</font>
      <textcolor>FFFFFFFF</textcolor>
      <label>$INFO[VideoPlayer.TVShowTitle]</label>
      <visible>VideoPlayer.Content(episodes)</visible>
    </control>

    <!-- Movie title -->
    <control type="label">
      <left>48</left><top>876</top><width>1400</width><height>48</height>
      <font>HBM_Title_M</font>
      <textcolor>FFFFFFFF</textcolor>
      <label>$INFO[VideoPlayer.Title]</label>
      <visible>!VideoPlayer.Content(episodes)</visible>
    </control>

    <!-- S/E/Title (TV, paused) -->
    <control type="label">
      <left>48</left><top>924</top><width>1400</width><height>36</height>
      <font>HBM_Body_M</font>
      <textcolor>CCFFFFff</textcolor>
      <label>S$INFO[VideoPlayer.Season] E$INFO[VideoPlayer.Episode]  $INFO[VideoPlayer.Title]</label>
      <visible>VideoPlayer.Content(episodes) + Player.Paused</visible>
    </control>

    <!-- Year (Movie, paused) -->
    <control type="label">
      <left>48</left><top>924</top><width>400</width><height>36</height>
      <font>HBM_Body_M</font>
      <textcolor>CCFFFFff</textcolor>
      <label>$INFO[VideoPlayer.Year]</label>
      <visible>!VideoPlayer.Content(episodes) + Player.Paused</visible>
    </control>

    <!-- Time remaining -->
    <control type="label">
      <left>1480</left><top>924</top><width>400</width><height>36</height>
      <font>HBM_Body_M</font>
      <textcolor>CCFFFFff</textcolor>
      <align>right</align>
      <label>-$INFO[Player.TimeRemaining]</label>
    </control>

    <!-- Seekbar — gray base with white played progress -->
    <control type="progress">
      <left>48</left><top>968</top><width>1824</width><height>6</height>
      <info>Player.Progress</info>
      <texturebg colordiffuse="4DFFFFFF">white.png</texturebg>
      <midtexture colordiffuse="FFFFFFFF">white.png</midtexture>
    </control>

    <!-- Seekbar focus capture — 1x1 off-screen so no focus indicator is visible.
         SmallStepBack/Forward = 1-step seek; hold triggers Rewind/Forward for smooth scrub. -->
    <control type="button" id="87">
      <left>-3000</left><top>-3000</top><width>1</width><height>1</height>
      <texturefocus /><texturenofocus />
      <label/><font/>
      <onup>600</onup>
      <ondown>608</ondown>
      <onleft>Action(SmallStepBack)</onleft>
      <onright>Action(SmallStepForward)</onright>
      <onclick condition="Player.Forwarding | Player.Rewinding">PlayerControl(Play)</onclick>
    </control>


    <!-- Transport controls — grouplist wraps to itself on left/right boundary -->
    <control type="grouplist" id="200">
      <left>820</left><top>992</top><width>400</width><height>56</height>
      <orientation>horizontal</orientation>
      <itemgap>12</itemgap>
      <onup>87</onup>
      <ondown>608</ondown>
      <onleft>609</onleft>
      <onright>605</onright>


      <!-- Skip back 10s -->
      <control type="button" id="603">
        <width>44</width><height>44</height>
        <label/><font/>
        <texturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_skip_back.png</texturefocus>
        <texturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_skip_back.png</texturenofocus>
        <onclick>PlayerControl(SmallSkipBackward)</onclick>
      </control>

      <!-- Play / Pause -->
      <control type="togglebutton" id="602">
        <width>44</width><height>56</height>
        <label/><font/>
        <texturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_pause.png</texturefocus>
        <texturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_pause.png</texturenofocus>
        <alttexturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_play.png</alttexturefocus>
        <alttexturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_play.png</alttexturenofocus>
        <usealttexture>Player.Paused | Player.Forwarding | Player.Rewinding</usealttexture>
        <onclick>PlayerControl(Play)</onclick>
      </control>

      <!-- Skip forward 10s -->
      <control type="button" id="604">
        <width>44</width><height>44</height>
        <label/><font/>
        <texturefocus colordiffuse="FFFFFFFF">special://skin/media/icons/player_skip_fwd.png</texturefocus>
        <texturenofocus colordiffuse="AAFFFFFF">special://skin/media/icons/player_skip_fwd.png</texturenofocus>
        <onclick>PlayerControl(SmallSkipForward)</onclick>
      </control>

    </control>

    <!-- Episodes button — toggles the episode tray -->
    <control type="button" id="608">
      <left>48</left><top>996</top><width>160</width><height>44</height>
      <texturefocus colordiffuse="14FFFFFF">white.png</texturefocus>
      <texturenofocus />
      <font>HBM_Body_M</font>
      <textcolor>AAFFFFFF</textcolor>
      <focusedcolor>FFFFFFFF</focusedcolor>
      <label>Episodes</label>
      <onclick>Skin.SetString(HBM.OSDEpisodesOpen,1)</onclick>
      <onclick>Skin.SetString(HBM.OSDEpisodesTab,episodes)</onclick>
      <onclick>SetFocus(800)</onclick>
      <onup>200</onup>
      <ondown>800</ondown>
      <onleft>607</onleft>
      <onright>609</onright>
    </control>

    <!-- You May Also Like button -->
    <control type="button" id="609">
      <left>224</left><top>996</top><width>220</width><height>44</height>
      <texturefocus colordiffuse="14FFFFFF">white.png</texturefocus>
      <texturenofocus />
      <font>HBM_Body_M</font>
      <textcolor>AAFFFFFF</textcolor>
      <focusedcolor>FFFFFFFF</focusedcolor>
