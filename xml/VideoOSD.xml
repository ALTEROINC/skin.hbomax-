          <label>You May Also Like</label>
          <visible>String.IsEqual(Skin.String(HBM.OSDEpisodesTab),ymal) + !Control.HasFocus(802)</visible>
        </control>
      </control>

      <!-- X close button (id=803) -->
      <control type="button" id="803">
        <left>1848</left><top>600</top><width>44</width><height>40</height>
        <texturefocus border="20" colordiffuse="22FFFFFF">special://skin/media/panel_rounded.png</texturefocus>
        <texturenofocus />
        <font>HBM_Body_M</font>
        <textcolor>AAFFFFFF</textcolor>
        <focusedcolor>FFFFFFFF</focusedcolor>
        <align>center</align><aligny>center</aligny>
        <label>×</label>
        <onclick>Skin.SetString(HBM.OSDEpisodesOpen,0)</onclick>
