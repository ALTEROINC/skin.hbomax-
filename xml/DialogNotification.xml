<?xml version="1.0" encoding="UTF-8"?>
<window>
  <zorder>3</zorder>
  <controls>
    <control type="group">
      <top>0</top>
      <right>0</right>
      <width>460</width>
      <height>112</height>

      <!-- Soft outer shadow, rounded. Widened +20px on the right (kept at left=-6,
           same as top/bottom) so the visible edge sits flush with the screen's right
           edge — panel_rounded.png's own corner curvature/padding otherwise reads as
           a small gap. The overshoot plus that corner just clips off-screen. -->
      <control type="image">
        <left>-6</left>
        <top>-6</top>
        <width>492</width>
        <height>124</height>
        <texture border="24" colordiffuse="26000000">special://skin/media/panel_rounded.png</texture>
      </control>

      <!-- Base card: semi-translucent black, rounded. Same +20px right overshoot. -->
      <control type="image">
        <width>480</width>
        <height>112</height>
        <texture border="24" colordiffuse="CC000000">special://skin/media/panel_rounded.png</texture>
      </control>

      <!-- Gloss sheen: soft white highlight across the upper portion. Inset 26px/8px —
           panel_rounded.png's border="24" corner radius means anything less than ~24px
           lets the gloss's straight corners poke past the base's rounded corners. -->
      <control type="image">
        <left>26</left>
        <top>8</top>
        <width>408</width>
        <height>40</height>
        <texture colordiffuse="22FFFFFF">special://skin/media/overlays/row_top_fade.png</texture>
      </control>

      <control type="image" id="400">
        <left>20</left>
        <top>21</top>
        <width>70</width>
        <height>70</height>
      </control>
      <control type="fadelabel" id="401">
        <left>108</left>
        <top>28</top>
        <width>332</width>
        <height>28</height>
        <font>HBM_Body_M</font>
        <textcolor>FFFFFFFF</textcolor>
      </control>
      <control type="fadelabel" id="402">
        <left>108</left>
        <top>58</top>
        <width>332</width>
        <height>40</height>
        <font>HBM_Body_S</font>
        <textcolor>E6FFFFFF</textcolor>
      </control>
    </control>
  </controls>
</window>
