      <!-- Autocomplete suggestions (id=9010) — shown above key rows -->
      <control type="panel" id="9010">
        <left>190</left><top>140</top>
        <width>1400</width><height>64</height>
        <orientation>vertical</orientation>
        <scrolltime tween="cubic" easing="out">500</scrolltime>
        <onleft>9010</onleft><onright>9010</onright>
        <onup>noop</onup><ondown>105</ondown>
        <visible>!Control.IsVisible(313) + Integer.IsGreater(Container(9010).NumItems,0)</visible>
        <itemlayout width="460" height="64">
          <control type="image">
            <left>8</left><top>4</top><width>444</width><height>56</height>
            <texture colordiffuse="14FFFFFF">white.png</texture>
          </control>
          <control type="label">
            <left>24</left><top>4</top><width>420</width><height>56</height>
            <label>$INFO[ListItem.Label]</label>
            <font>HBM_Body_M</font>
            <textcolor>TextSecondary</textcolor>
            <aligny>center</aligny>
          </control>
        </itemlayout>
        <focusedlayout width="460" height="64">
          <control type="image">
            <left>8</left><top>4</top><width>444</width><height>56</height>
            <texture colordiffuse="FocusFill">white.png</texture>
            <include>Animation_FocusTextureFade</include>
