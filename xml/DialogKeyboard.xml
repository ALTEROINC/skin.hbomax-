<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">300</defaultcontrol>
  <controls>

    <control type="group">
      <left>0</left><top>480</top>
      <width>1920</width><height>600</height>
      <visible>!Window.IsVisible(numericinput)</visible>
      <animation type="WindowOpen">
        <effect type="fade" start="0" end="100" time="220" tween="sine" easing="out"/>
        <effect type="slide" start="0,600" end="0,0" time="260" tween="cubic" easing="out"/>
      </animation>
      <animation type="WindowClose">
        <effect type="fade" start="100" end="0" time="180" tween="sine" easing="in"/>
        <effect type="slide" start="0,0" end="0,600" time="220" tween="cubic" easing="in"/>
      </animation>

      <!-- Panel background -->
      <control type="image">
        <left>0</left><top>0</top>
        <width>1920</width><height>600</height>
        <texture colordiffuse="F0101418">white.png</texture>
      </control>

      <!-- Top edge accent -->
      <control type="image">
        <left>0</left><top>0</top>
        <width>1920</width><height>1</height>
        <texture colordiffuse="22FFFFFF">white.png</texture>
      </control>

      <!-- Header prompt (id=311) -->
      <control type="label" id="311">
        <left>190</left><top>20</top>
        <width>1400</width><height>44</height>
        <font>HBM_Display_M</font>
        <label></label>
        <align>center</align><aligny>center</aligny>
        <textcolor>TextPrimary</textcolor>
      </control>

      <!-- Input field background -->
      <control type="image">
        <left>190</left><top>76</top>
        <width>1400</width><height>52</height>
        <texture border="8" colordiffuse="22FFFFFF">white.png</texture>
      </control>

      <!-- Text input edit (id=312) -->
