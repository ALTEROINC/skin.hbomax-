        <width>1400</width><height>52</height>
        <font>HBM_Body_M</font>
        <align>center</align><aligny>center</aligny>
        <textcolor>TextPrimary</textcolor>
        <texturefocus/>
        <texturenofocus/>
      </control>

      <!-- IP / multi-tap input lines (id=313, 314) — shown when keyboard is in IP/numpad mode -->
