<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
  <defaultcontrol>5</defaultcontrol>
  <controls>

    <!-- Backdrop dim -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <texture colordiffuse="CC000000">white.png</texture>
    </control>

    <!-- Dialog panel: 1680x880, centered -->
    <control type="group">
      <left>120</left><top>100</top><width>1680</width><height>880</height>

      <!-- Panel background -->
      <control type="image">
        <left>0</left><top>0</top><width>1680</width><height>880</height>
        <texture colordiffuse="F0141414">white.png</texture>
      </control>

      <!-- Top divider -->
      <control type="image">
        <left>0</left><top>72</top><width>1680</width><height>1</height>
        <texture colordiffuse="16FFFFFF">white.png</texture>
      </control>

      <!-- Bottom divider (above action strip) -->
      <control type="image">
        <left>0</left><top>796</top><width>1680</width><height>1</height>
        <texture colordiffuse="16FFFFFF">white.png</texture>
      </control>

      <!-- Header label (id=2, populated by Kodi with addon name) -->
      <control type="label" id="2">
        <left>32</left><top>0</top><width>1400</width><height>72</height>
        <font>HBM_Display_M</font>
        <textcolor>TextPrimary</textcolor>
        <aligny>center</aligny>
      </control>

      <!-- Sidebar background -->
      <control type="image">
        <left>0</left><top>73</top><width>280</width><height>723</height>
        <texture colordiffuse="0A141414">white.png</texture>
      </control>

      <!-- Sidebar vertical divider -->
      <control type="image">
        <left>280</left><top>73</top><width>1</width><height>723</height>
        <texture colordiffuse="16FFFFFF">white.png</texture>
      </control>

      <!-- Categories grouplist (id=3) -->
      <control type="grouplist" id="3">
        <left>0</left><top>73</top><width>280</width><height>620</height>
        <itemgap>0</itemgap>
        <orientation>vertical</orientation>
        <onleft>9001</onleft>
        <onright>5</onright>
        <onup>20</onup>
        <ondown>20</ondown>
      </control>

      <!-- Settings level toggle (id=20) -->
      <control type="radiobutton" id="20">
        <left>0</left><top>707</top><width>280</width><height>56</height>
        <font>HBM_Body_S</font>
        <textcolor>TextMuted</textcolor>
        <focusedcolor>TextSecondary</focusedcolor>
        <aligny>center</aligny>
        <onclick>SettingsLevelChange</onclick>
        <textoffsetx>48</textoffsetx>
        <texturenofocus />
        <texturefocus colordiffuse="0AFFFFFF">white.png</texturefocus>
        <radioposx>16</radioposx><radioposy>18</radioposy>
        <radiowidth>20</radiowidth><radioheight>20</radioheight>
        <textureradioonfocus colordiffuse="FFFFFFFF">white.png</textureradioonfocus>
        <textureradioonnofocus colordiffuse="CCFFFFFF">white.png</textureradioonnofocus>
        <textureradioofffocus colordiffuse="33FFFFFF">white.png</textureradioofffocus>
        <textureradiooffnofocus colordiffuse="22FFFFFF">white.png</textureradiooffnofocus>
        <onleft>9001</onleft>
        <onright>5</onright>
        <onup>3</onup>
        <ondown>3</ondown>
      </control>

      <!-- Default category button template (id=10) -->
      <control type="button" id="10">
        <width>280</width><height>52</height>
        <textoffsetx>24</textoffsetx>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus colordiffuse="0AFFFFFF">white.png</texturenofocus>
      </control>

      <!-- Settings grouplist (id=5) -->
      <control type="grouplist" id="5">
        <left>296</left><top>81</top><width>1316</width><height>630</height>
        <pagecontrol>60</pagecontrol>
        <onleft>3</onleft>
        <onright>60</onright>
        <onup>5</onup>
        <ondown>5</ondown>
      </control>

      <!-- Scrollbar (id=60) -->
      <control type="scrollbar" id="60">
        <left>1624</left><top>81</top><width>8</width><height>630</height>
        <orientation>vertical</orientation>
        <texturesliderbackground colordiffuse="1AFFFFFF">white.png</texturesliderbackground>
        <textureslider colordiffuse="66FFFFFF">white.png</textureslider>
        <onleft>5</onleft>
        <onright>9001</onright>
        <onup>60</onup>
        <ondown>9001</ondown>
      </control>

      <!-- Description textbox (id=6) -->
      <control type="textbox" id="6">
        <left>296</left><top>724</top><width>1376</width><height>60</height>
        <font>HBM_Body_S</font>
        <textcolor>TextMuted</textcolor>
        <autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
      </control>

      <!-- Action buttons: OK (id=28), Cancel (id=29), Defaults (id=30) — centered at bottom -->
      <control type="grouplist" id="9001">
        <left>0</left><top>812</top><width>1680</width><height>56</height>
        <orientation>horizontal</orientation>
        <align>center</align>
        <itemgap>16</itemgap>
        <onleft>9001</onleft>
        <onright>9001</onright>
        <onup>5</onup>
        <ondown>3</ondown>
        <control type="button" id="28">
          <width>200</width><height>56</height>
          <label>$LOCALIZE[186]</label>
          <font>HBM_Body_M</font>
          <textcolor>TextSecondary</textcolor>
          <focusedcolor>TextPrimary</focusedcolor>
          <texturefocus border="8" colordiffuse="FocusFill">white.png</texturefocus>
          <texturenofocus border="8" colordiffuse="1AFFFFFF">white.png</texturenofocus>
          <align>center</align><aligny>center</aligny>
        </control>
        <control type="button" id="29">
          <width>200</width><height>56</height>
          <label>$LOCALIZE[222]</label>
          <font>HBM_Body_M</font>
          <textcolor>TextSecondary</textcolor>
          <focusedcolor>TextPrimary</focusedcolor>
          <texturefocus border="8" colordiffuse="FocusFill">white.png</texturefocus>
          <texturenofocus border="8" colordiffuse="14FFFFFF">white.png</texturenofocus>
          <align>center</align><aligny>center</aligny>
        </control>
        <control type="button" id="30">
          <width>200</width><height>56</height>
          <label>$LOCALIZE[409]</label>
          <font>HBM_Body_M</font>
          <textcolor>TextSecondary</textcolor>
          <focusedcolor>TextPrimary</focusedcolor>
          <texturefocus border="8" colordiffuse="FocusFill">white.png</texturefocus>
          <texturenofocus border="8" colordiffuse="0EFFFFFF">white.png</texturenofocus>
          <align>center</align><aligny>center</aligny>
        </control>
      </control>

      <!-- ── Setting control templates — Kodi clones these to populate id=5.
           NO <visible>false</visible> here: clones inherit that state and become invisible.
           Kodi hides the originals programmatically at runtime. -->

      <!-- Default button (id=7) -->
      <control type="button" id="7">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus />
      </control>

      <!-- Default radiobutton (id=8) -->
      <control type="radiobutton" id="8">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <textwidth>1140</textwidth>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus />
        <radioposx>1272</radioposx><radioposy>16</radioposy>
        <radiowidth>24</radiowidth><radioheight>24</radioheight>
        <textureradioonfocus colordiffuse="FFFFFFFF">white.png</textureradioonfocus>
        <textureradioonnofocus colordiffuse="CCFFFFFF">white.png</textureradioonnofocus>
        <textureradioofffocus colordiffuse="33FFFFFF">white.png</textureradioofffocus>
        <textureradiooffnofocus colordiffuse="22FFFFFF">white.png</textureradiooffnofocus>
      </control>

      <!-- Default spincontrolex (id=9) -->
      <control type="spincontrolex" id="9">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus />
      </control>

      <!-- Separator (id=11) -->
      <control type="image" id="11">
        <height>1</height>
        <texture colordiffuse="16FFFFFF">white.png</texture>
      </control>

      <!-- Default edit (id=12) -->
      <control type="edit" id="12">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus colordiffuse="1AFFFFFF">white.png</texturenofocus>
      </control>

      <!-- Default sliderex (id=13) -->
      <control type="sliderex" id="13">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <textwidth>900</textwidth>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus />
      </control>

      <!-- Default label/heading (id=14) -->
      <control type="label" id="14">
        <width>1316</width><height>48</height>
        <textoffsetx>16</textoffsetx>
        <font>HBM_Meta_S</font>
        <textcolor>TextMuted</textcolor>
        <aligny>center</aligny>
      </control>

      <!-- Default colorbutton (id=15) -->
      <control type="colorbutton" id="15">
        <width>1316</width><height>56</height>
        <textoffsetx>16</textoffsetx>
        <align>left</align><aligny>center</aligny>
        <font>HBM_Body_M</font>
        <textcolor>TextSecondary</textcolor>
        <focusedcolor>TextPrimary</focusedcolor>
        <texturefocus colordiffuse="FocusFill">white.png</texturefocus>
        <texturenofocus />
      </control>

    </control>
  </controls>
</window>
