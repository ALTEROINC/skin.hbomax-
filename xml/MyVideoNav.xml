<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">50</defaultcontrol>
  <backgroundcolor>BackgroundBase</backgroundcolor>
  <views>50</views>
  <controls>
    <include>HBM_Runtime_Background</include>

    <control type="label">
      <left>120</left>
      <top>86</top>
      <width>900</width>
      <height>54</height>
      <label>Videos</label>
      <font>HBM_Display_M</font>
      <textcolor>TextPrimary</textcolor>
    </control>

    <control type="group">
      <left>96</left>
      <top>170</top>
      <width>1728</width>
      <height>814</height>
      <control type="image">
        <left>-6</left>
        <top>-6</top>
        <width>1740</width>
        <height>826</height>
        <texture border="24" colordiffuse="16000000">special://skin/media/panel_rounded.png</texture>
      </control>
      <control type="image">
        <left>0</left>
        <top>0</top>
        <width>1728</width>
        <height>814</height>
        <texture border="24" colordiffuse="F10F1420">special://skin/media/panel_rounded.png</texture>
      </control>

      <control type="label">
        <left>36</left>
        <top>26</top>
        <width>420</width>
        <height>24</height>
