<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
  <defaultcontrol always="true">2</defaultcontrol>
  <backgroundcolor>BackgroundBase</backgroundcolor>
  <onload>Skin.SetString(HBM.ReturnFocus,2)</onload>
  <onload>Skin.SetString(HBM.ActiveRow,0)</onload>
  <onload>Skin.SetString(HBM.InDialog,1)</onload>
  <onunload>Skin.Reset(HBM.InDialog)</onunload>
  <onload>Skin.SetString(HBM.ShowTMDB,$INFO[ListItem.UniqueID(tmdb)])</onload>
  <onload>Skin.SetString(HBM.CurrentSeason,1)</onload>
  <onload>Skin.Reset(HBM.SeasonOpen)</onload>
  <!-- Auto trailer preview: same 7s-wait / spinner-while-resolving / reveal-on-
       actually-playing pattern as the Home hero, adapted for this dialog's single
       fixed ListItem (no rotation/advance needed — see dialoginfo_trailer_*.py). -->
  <onload>AlarmClock(HBMInfoTrailerStart,RunScript(special://skin/resources/scripts/dialoginfo_trailer_start.py),00:00:07,silent)</onload>
  <onunload>RunScript(special://skin/resources/scripts/dialoginfo_trailer_stop.py)</onunload>

  <controls>

    <!-- Dark base fill — fixed, always covers the screen -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <aspectratio>stretch</aspectratio>
      <texture colordiffuse="BackgroundBase">white.png</texture>
    </control>

    <!-- Trailer videowindow — deliberately standalone, NOT nested inside the scroll
         wrapper group below (which has a conditional slide animation for episode
         browsing): Kodi's native video overlay doesn't reliably composite through
         an animated ancestor group the way normal texture controls do (confirmed
         while building the Home row-focus trailer feature). Rendered here, before
         the scroll wrapper, so its dim/fade/floor overlays still layer on top of
         it same as the static fanart. Fixed in place rather than scrolling with
         episode browsing — a known, accepted tradeoff. -->
    <control type="videowindow">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <visible>String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
    </control>

    <!-- Scroll wrapper: hero backdrop + content slide together when episodes focused -->
    <control type="group">
      <left>0</left><top>0</top><width>1920</width><height>1400</height>
      <animation effect="slide" start="0,0" end="0,-300" time="250" tween="quadratic" easing="out" condition="Control.HasFocus(500) | Control.HasFocus(501) | Control.HasFocus(502)">Conditional</animation>

      <!-- Fanart backdrop -->
      <control type="image">
        <left>0</left><top>0</top><width>1920</width><height>1080</height>
        <aspectratio>scale</aspectratio>
        <fadetime>500</fadetime>
        <texture>$INFO[ListItem.Art(fanart)]</texture>
        <visible>!String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
      </control>
      <control type="image">
        <left>0</left><top>0</top><width>1920</width><height>1080</height>
        <aspectratio>scale</aspectratio>
        <fadetime>500</fadetime>
        <visible>String.IsEmpty(ListItem.Art(fanart)) + !String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        <texture>$INFO[ListItem.Art(tvshow.fanart)]</texture>
      </control>
      <control type="image">
        <left>0</left><top>0</top><width>1920</width><height>1080</height>
        <aspectratio>scale</aspectratio>
        <fadetime>500</fadetime>
        <visible>String.IsEmpty(ListItem.Art(fanart)) + String.IsEmpty(ListItem.Art(tvshow.fanart)) + !String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        <texture>$INFO[ListItem.Art(landscape)]</texture>
      </control>

      <!-- Subtle overall dim -->
      <control type="image">
        <left>0</left><top>0</top><width>1920</width><height>756</height>
        <aspectratio>stretch</aspectratio>
        <texture colordiffuse="33000000">white.png</texture>
      </control>

      <!-- Bottom fade -->
      <control type="image">
        <left>0</left><top>420</top><width>1920</width><height>400</height>
        <aspectratio>stretch</aspectratio>
        <texture>special://skin/media/overlays/row_top_fade.png</texture>
      </control>

      <!-- Solid dark floor below hero -->
      <control type="image">
        <left>0</left><top>756</top><width>1920</width><height>644</height>
        <aspectratio>stretch</aspectratio>
        <texture colordiffuse="BackgroundBase">white.png</texture>
      </control>

      <!-- Content group -->
      <control type="group">
        <left>160</left><top>0</top><width>1760</width><height>1400</height>

        <!-- Genre badge -->
        <control type="label">
          <left>0</left><top>592</top><width>780</width><height>24</height>
          <label>$INFO[ListItem.Genre]</label>
          <font>HBM_Meta_S</font>
          <textcolor>TextHeroMeta</textcolor>
        </control>

        <!-- Clear logo -->
        <control type="image">
          <left>0</left><top>420</top><width>560</width><height>190</height>
          <aspectratio align="left" aligny="center">keep</aspectratio>
          <fadetime>400</fadetime>
          <texture>$INFO[ListItem.Art(clearlogo)]</texture>
          <visible>!String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        </control>

        <!-- Title fallback when no clearlogo -->
        <control type="label">
          <left>0</left><top>420</top><width>780</width><height>190</height>
          <label>$INFO[ListItem.Title]</label>
          <font>HBM_Display_L</font>
          <textcolor>TextPrimary</textcolor>
          <aligny>center</aligny>
          <visible>String.IsEmpty(ListItem.Art(clearlogo)) + !String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        </control>

        <!-- Trailer-active clear logo: separate control (not an animated version of
             the one above) since it needs a genuinely centered box — the normal
             clearlogo is intentionally left-anchored via aspectratio align=left,
             which can't be centered just by animating position. left=-160/width=1920
             re-spans the full screen width despite this group's own left=160 offset. -->
        <control type="image">
          <left>-160</left><top>20</top><width>1920</width><height>120</height>
          <aspectratio align="center" aligny="center">keep</aspectratio>
          <fadetime>400</fadetime>
          <texture>$INFO[ListItem.Art(clearlogo)]</texture>
          <visible>String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        </control>
        <control type="label">
          <left>-160</left><top>20</top><width>1920</width><height>120</height>
          <label>$INFO[ListItem.Title]</label>
          <font>HBM_Display_L</font>
          <textcolor>TextPrimary</textcolor>
          <align>center</align>
          <aligny>center</aligny>
          <visible>String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEqual(Skin.String(HBM.InfoTrailerPlaying),1)</visible>
        </control>

        <!-- Meta: year · MPAA · duration -->
        <control type="label">
          <left>0</left><top>618</top><width>780</width><height>24</height>
          <label>$INFO[ListItem.Year]  ·  $INFO[ListItem.MPAA]  ·  $INFO[ListItem.Duration]</label>
          <font>HBM_Meta_S</font>
          <textcolor>TextHeroMeta</textcolor>
        </control>

        <!-- Primary play button hit area (id=2) -->
        <control type="button" id="2">
          <left>0</left><top>650</top><width>300</width><height>56</height>
          <label></label>
          <texturenofocus>-</texturenofocus>
          <texturefocus>-</texturefocus>
          <onclick>RunScript(special://skin/resources/scripts/dialoginfo_trailer_stop.py)</onclick>
          <onclick>Skin.SetString(HBM.PlayedFromDialog,1)</onclick>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie)">Skin.SetString(HBM.DialogItemType,movie)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie)">Skin.SetString(HBM.DialogItemType,tv)</onclick>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(ListItem.FileNameAndPath)">PlayMedia($INFO[ListItem.FileNameAndPath])</onclick>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(ListItem.FileNameAndPath)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_id=$INFO[ListItem.UniqueID(tmdb)]&amp;tmdb_type=movie)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Episode)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=$INFO[Container(510).ListItemAbsolute(0).Season]&amp;episode=$INFO[Container(510).ListItemAbsolute(0).Episode])</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Episode)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=$INFO[Container(511).ListItemAbsolute(0).Season]&amp;episode=$INFO[Container(511).ListItemAbsolute(0).Episode])</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + String.IsEmpty(Container(511).ListItemAbsolute(0).Season)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=1&amp;episode=1)</onclick>
          <onfocus>Skin.SetString(HBM.ReturnFocus,2)</onfocus>
          <onleft>200</onleft>
          <onright condition="ListItem.IsResumable | (!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season))">6</onright>
          <onright>4</onright>
          <ondown>4</ondown>
        </control>
        <!-- Primary button background (nofocus / focus) -->
        <control type="image">
          <left>0</left><top>650</top><width>300</width><height>56</height>
          <texture border="6" colordiffuse="BBFFFFFF">special://skin/media/panel_rect.png</texture>
          <visible>!Control.HasFocus(2)</visible>
        </control>
        <control type="image">
          <left>0</left><top>650</top><width>300</width><height>56</height>
          <texture border="6" colordiffuse="DDFFFFFF">special://skin/media/panel_rect.png</texture>
          <visible>Control.HasFocus(2)</visible>
        </control>
        <!-- Play icon — centered-left in 300px button -->
        <control type="image">
          <left>70</left><top>665</top><width>26</width><height>26</height>
          <texture>special://skin/media/icons/play-fill.png</texture>
        </control>
        <!-- Label: Watch Now (movie, not started) -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Watch Now</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>String.IsEqual(ListItem.DBTYPE,movie) + !ListItem.IsResumable</visible>
        </control>
        <!-- Label: Continue Watching (movie, resumable) -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Continue Watching</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>String.IsEqual(ListItem.DBTYPE,movie) + ListItem.IsResumable</visible>
        </control>
        <!-- Label: Watch Ep 1 (tv show, not started) -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Watch Ep 1</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + String.IsEmpty(Container(511).ListItemAbsolute(0).Season)</visible>
        </control>
        <!-- Label: TMDb Helper fallback first episode -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Watch S$INFO[Container(511).ListItemAbsolute(0).Season] E$INFO[Container(511).ListItemAbsolute(0).Episode]</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Episode) + Integer.IsEqual(Container(511).ListItemAbsolute(0).Property(ResumeTime),0)</visible>
        </control>
        <!-- Label: TMDb Helper fallback resumable episode -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Continue S$INFO[Container(511).ListItemAbsolute(0).Season] E$INFO[Container(511).ListItemAbsolute(0).Episode]</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Episode) + Integer.IsGreater(Container(511).ListItemAbsolute(0).Property(ResumeTime),0)</visible>
        </control>
        <!-- Label: Trakt-resolved up next target -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Watch S$INFO[Container(510).ListItemAbsolute(0).Season] E$INFO[Container(510).ListItemAbsolute(0).Episode]</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Episode) + Integer.IsEqual(Container(510).ListItemAbsolute(0).Property(ResumeTime),0)</visible>
        </control>
        <!-- Label: Trakt-resolved resumable target -->
        <control type="label">
          <left>104</left><top>650</top><width>188</width><height>56</height>
          <label>Continue S$INFO[Container(510).ListItemAbsolute(0).Season] E$INFO[Container(510).ListItemAbsolute(0).Episode]</label>
          <font>HBM_Nav_M</font>
          <textcolor>FF161C24</textcolor>
          <align>left</align><aligny>center</aligny>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Episode) + Integer.IsGreater(Container(510).ListItemAbsolute(0).Property(ResumeTime),0)</visible>
        </control>

        <!-- Restart button (id=6) — ghost, only when resumable -->
        <control type="button" id="6">
          <left>312</left><top>650</top><width>200</width><height>56</height>
          <label>Restart</label>
          <font>HBM_Nav_M</font>
          <align>center</align><aligny>center</aligny>
          <textcolor>FFFFFFFF</textcolor>
          <focusedcolor>FFFFFFFF</focusedcolor>
          <texturenofocus border="6" colordiffuse="33FFFFFF">special://skin/media/panel_rect.png</texturenofocus>
          <texturefocus border="6" colordiffuse="55FFFFFF">special://skin/media/panel_rect.png</texturefocus>
          <onclick>RunScript(special://skin/resources/scripts/dialoginfo_trailer_stop.py)</onclick>
          <onclick>Skin.SetString(HBM.PlayedFromDialog,1)</onclick>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie)">Skin.SetString(HBM.DialogItemType,movie)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie)">Skin.SetString(HBM.DialogItemType,tv)</onclick>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie)">PlayMedia($INFO[ListItem.FileNameAndPath],noresume)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Episode)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=$INFO[Container(510).ListItemAbsolute(0).Season]&amp;episode=$INFO[Container(510).ListItemAbsolute(0).Episode],noresume)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Season) + !String.IsEmpty(Container(511).ListItemAbsolute(0).Episode)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=$INFO[Container(511).ListItemAbsolute(0).Season]&amp;episode=$INFO[Container(511).ListItemAbsolute(0).Episode],noresume)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie) + String.IsEmpty(Container(510).ListItemAbsolute(0).Season) + String.IsEmpty(Container(511).ListItemAbsolute(0).Season)">PlayMedia(plugin://plugin.video.themoviedb.helper/?info=play&amp;tmdb_type=tv&amp;tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)]&amp;season=1&amp;episode=1,noresume)</onclick>
          <onfocus>Skin.SetString(HBM.ReturnFocus,6)</onfocus>
          <onleft>2</onleft>
          <onright>4</onright>
          <ondown>4</ondown>
          <visible>ListItem.IsResumable | (!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season))</visible>
        </control>

        <!-- My List (id=4) — no background, icon above label -->
        <control type="button" id="4">
          <left>0</left><top>718</top><width>110</width><height>58</height>
          <label></label>
          <texturenofocus>-</texturenofocus>
          <texturefocus>-</texturefocus>
          <onclick condition="String.IsEqual(ListItem.DBTYPE,movie)">RunScript(plugin.video.themoviedb.helper,sync_trakt,tmdb_type=movie,tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)],sync_type=watchlist)</onclick>
          <onclick condition="!String.IsEqual(ListItem.DBTYPE,movie)">RunScript(plugin.video.themoviedb.helper,sync_trakt,tmdb_type=tv,tmdb_id=$INFO[Skin.String(HBM.ShowTMDB)],sync_type=watchlist)</onclick>
          <onfocus>Skin.SetString(HBM.ReturnFocus,4)</onfocus>
          <onup>2</onup>
          <onleft condition="ListItem.IsResumable | (!String.IsEqual(ListItem.DBTYPE,movie) + !String.IsEmpty(Container(510).ListItemAbsolute(0).Season))">6</onleft>
          <onleft>200</onleft>
          <onright>5</onright>
          <ondown>500</ondown>
        </control>
        <!-- My List icon — bright when focused, dim when not -->
        <control type="image">
          <left>39</left><top>720</top><width>32</width><height>32</height>
          <texture colordiffuse="FFFFFFFF">special://skin/media/icons/plus-bold.png</texture>
          <visible>Control.HasFocus(4)</visible>
        </control>
        <control type="image">
          <left>39</left><top>720</top><width>32</width><height>32</height>
          <texture colordiffuse="66FFFFFF">special://skin/media/icons/plus-bold.png</texture>
          <visible>!Control.HasFocus(4)</visible>
        </control>
        <!-- My List label — bright when focused, dim when not -->
        <control type="label">
          <left>0</left><top>756</top><width>110</width><height>22</height>
          <label>My List</label>
          <font>HBM_Meta_S</font>
          <textcolor>FFFFFFFF</textcolor>
          <align>center</align>
          <aligny>center</aligny>
          <visible>Control.HasFocus(4)</visible>
        </control>
        <control type="label">
          <left>0</left><top>756</top><width>110</width><height>22</height>
          <label>My List</label>
          <font>HBM_Meta_S</font>
          <textcolor>66FFFFFF</textcolor>
          <align>center</align>
          <aligny>center</aligny>
          <visible>!Control.HasFocus(4)</visible>
        </control>

        <!-- Trailer (id=5) — only shown when ListItem.Trailer is populated -->
        <control type="button" id="5">
          <left>120</left><top>718</top><width>110</width><height>58</height>
          <label></label>
          <texturenofocus>-</texturenofocus>
          <texturefocus>-</texturefocus>
          <onclick>RunScript(special://skin/resources/scripts/dialoginfo_trailer_stop.py)</onclick>
          <onclick>PlayMedia($INFO[ListItem.Trailer])</onclick>
          <onfocus>Skin.SetString(HBM.ReturnFocus,5)</onfocus>
          <onup>2</onup>
          <onleft>4</onleft>
          <onright>200</onright>
          <ondown>500</ondown>
          <visible>!String.IsEmpty(ListItem.Trailer)</visible>
        </control>
        <!-- Trailer icon — bright when focused, dim when not -->
        <control type="image">
          <left>159</left><top>720</top><width>32</width><height>32</height>
          <texture colordiffuse="FFFFFFFF">special://skin/media/icons/film-slate-fill.png</texture>
          <visible>Control.HasFocus(5) + !String.IsEmpty(ListItem.Trailer)</visible>
        </control>
        <control type="image">
          <left>159</left><top>720</top><width>32</width><height>32</height>
          <texture colordiffuse="66FFFFFF">special://skin/media/icons/film-slate-fill.png</texture>
          <visible>!Control.HasFocus(5) + !String.IsEmpty(ListItem.Trailer)</visible>
        </control>
        <!-- Trailer label — bright when focused, dim when not -->
        <control type="label">
          <left>120</left><top>756</top><width>110</width><height>22</height>
          <label>Trailer</label>
          <font>HBM_Meta_S</font>
          <textcolor>FFFFFFFF</textcolor>
          <align>center</align>
          <aligny>center</aligny>
          <visible>Control.HasFocus(5) + !String.IsEmpty(ListItem.Trailer)</visible>
        </control>
        <control type="label">
          <left>120</left><top>756</top><width>110</width><height>22</height>
          <label>Trailer</label>
          <font>HBM_Meta_S</font>
          <textcolor>66FFFFFF</textcolor>
          <align>center</align>
          <aligny>center</aligny>
          <visible>!Control.HasFocus(5) + !String.IsEmpty(ListItem.Trailer)</visible>
        </control>

        <!-- Plot — below buttons, autoscrolls long descriptions -->
        <control type="textbox">
          <left>0</left><top>790</top><width>600</width><height>80</height>
          <font>HBM_Body_M</font>
          <textcolor>TextSecondary</textcolor>
          <label>$INFO[ListItem.Plot]</label>
          <autoscroll delay="3000" time="6000" repeat="8000">true</autoscroll>
        </control>

        <!-- Episodes section — TV shows only -->
        <control type="group">
          <left>0</left><top>890</top><width>1760</width><height>450</height>
          <visible>!String.IsEqual(ListItem.DBTYPE,movie)</visible>

          <!-- "Episodes" label -->
          <control type="label">
            <left>0</left><top>0</top><width>200</width><height>28</height>
            <label>Episodes</label>
            <font>HBM_Nav_M</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
          </control>

          <!-- Grey divider -->
          <control type="image">
            <left>0</left><top>30</top><width>1600</width><height>2</height>
            <texture colordiffuse="44FFFFFF">white.png</texture>
          </control>

          <!-- White underline under "Episodes" only -->
          <control type="image">
            <left>0</left><top>30</top><width>110</width><height>2</height>
            <texture colordiffuse="FFFFFFFF">white.png</texture>
          </control>

          <!-- Season picker (id=500) — safe ID avoids Kodi's reserved dialog control IDs -->
          <control type="button" id="500">
