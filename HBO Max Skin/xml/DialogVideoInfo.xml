<?xml version="1.0" encoding="utf-8"?>
<window>
    <defaultcontrol always="true">530</defaultcontrol>
    <backgroundcolor>$INFO[Skin.String(ColorBackground)]</backgroundcolor>
    <onback>PreviousMenu</onback>

    <controls>
        <!-- Zone 1: Background -->
        <control type="group" id="599">
            <left>1784</left>
            <top>32</top>
            <width>56</width>
            <height>78</height>
            <include content="ButtonIcon">
                <param name="ControlId" value="599" />
                <param name="Icon" value="special://skin/media/hbomax/icons/close.png" />
                <param name="Action" value="PreviousMenu" />
                <param name="Tooltip" value="Close" />
                <param name="Width" value="56" />
                <param name="Height" value="56" />
                <param name="IconSize" value="28" />
            </include>
        </control>

        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture background="true">$VAR[HeroFanartVar]</texture>
            <aspectratio scalediffuse="false">scale</aspectratio>
            <animation effect="fade" start="0" end="100" time="600" tween="sine">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="300" tween="sine">WindowClose</animation>
        </control>

        <control type="image">
            <left>0</left>
            <top>380</top>
            <width>1920</width>
            <height>700</height>
            <texture>special://skin/media/hbomax/hero-gradient.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>

        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="$INFO[Skin.String(ColorOverlay)]">white.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>

        <!-- Zone 2: Hero info block -->
        <control type="group">
            <left>80</left>
            <top>80</top>
            <width>1760</width>
            <height>400</height>
            <animation effect="slide" start="0,40" end="0,0" time="500" tween="back" easing="out" delay="200">WindowOpen</animation>

            <control type="group">
                <left>0</left>
                <top>0</top>
                <width>800</width>
                <height>400</height>

                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>400</width>
                    <height>120</height>
                    <texture background="true">$VAR[ClearLogoVar]</texture>
                    <aspectratio>keep</aspectratio>
                    <visible>!String.IsEmpty(ListItem.Art(clearlogo))</visible>
                </control>

                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>800</width>
                    <height>80</height>
                    <font>HeroTitle</font>
                    <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <visible>String.IsEmpty(ListItem.Art(clearlogo))</visible>
                </control>

                <control type="grouplist">
                    <left>0</left>
                    <top>136</top>
                    <width>800</width>
                    <height>32</height>
                    <itemgap>12</itemgap>
                    <orientation>horizontal</orientation>

                    <control type="label">
                        <width>90</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <label>$INFO[ListItem.Year]</label>
                    </control>

                    <control type="label">
                        <width>20</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <align>center</align>
                        <label>·</label>
                    </control>

                    <control type="label">
                        <width>110</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <label>$VAR[RatingVar]</label>
                    </control>

                    <control type="label">
                        <width>20</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <align>center</align>
                        <label>·</label>
                    </control>

                    <control type="label">
                        <width>160</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <label>$VAR[RuntimeVar]</label>
                    </control>

                    <control type="label">
                        <width>20</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <align>center</align>
                        <label>·</label>
                    </control>

                    <control type="label">
                        <width>320</width>
                        <height>32</height>
                        <font>MetadataInfo</font>
                        <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                        <label>$INFO[ListItem.Genre]</label>
                    </control>
                </control>

                <control type="textbox">
                    <left>0</left>
                    <top>192</top>
                    <width>760</width>
                    <height>136</height>
                    <font>DialogBody</font>
                    <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                    <label>$INFO[ListItem.Plot]</label>
                    <autoscroll>false</autoscroll>
                </control>

                <control type="image">
                    <left>0</left>
                    <top>288</top>
                    <width>760</width>
                    <height>40</height>
                    <texture>special://skin/media/hbomax/hero-gradient.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <control type="grouplist">
                    <left>0</left>
                    <top>344</top>
                    <width>760</width>
                    <height>56</height>
                    <itemgap>16</itemgap>
                    <orientation>horizontal</orientation>

                    <control type="group" id="530">
                        <width>200</width>
                        <height>56</height>
                        <include content="ButtonPrimary">
                            <param name="ControlId" value="530" />
                            <param name="Label" value="▶  Play" />
                            <param name="Icon" value="special://skin/media/hbomax/icons/play.png" />
                            <param name="Action" value="PlayMedia($INFO[ListItem.FileNameAndPath])" />
                        </include>
                    </control>

                    <control type="group" id="531">
                        <width>200</width>
                        <height>56</height>
                        <include content="ButtonSecondary">
                            <param name="ControlId" value="531" />
                            <param name="Label" value="+ Watchlist" />
                            <param name="Icon" value="special://skin/media/hbomax/icons/plus.png" />
                            <param name="Action" value="RunScript(script.skin.helper.service,action=favorites)" />
                        </include>
                    </control>

                    <control type="group" id="532">
                        <width>200</width>
                        <height>56</height>
                        <include content="ButtonSecondary">
                            <param name="ControlId" value="532" />
                            <param name="Label" value="↓ Download" />
                            <param name="Icon" value="special://skin/media/hbomax/icons/download.png" />
                            <param name="Action" value="RunScript(script.skin.helper.service,action=download)" />
                        </include>
                    </control>
                </control>
            </control>

            <control type="group" id="540">
                <left>1480</left>
                <top>20</top>
                <width>220</width>
                <height>320</height>

                <control type="image">
                    <left>12</left>
                    <top>12</top>
                    <width>200</width>
                    <height>300</height>
                    <texture>special://skin/media/hbomax/card-shadow.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>300</height>
                    <texture background="true">$VAR[CardArtVar]</texture>
                    <aspectratio>scale</aspectratio>
                </control>
            </control>
        </control>

        <!-- Zone 3: Content rows -->
        <control type="group">
            <left>80</left>
            <top>520</top>
            <width>1760</width>
            <height>500</height>
            <animation effect="fade" start="0" end="100" time="400" tween="sine" delay="400">WindowOpen</animation>

            <control type="label">
                <left>0</left>
                <top>0</top>
                <width>300</width>
                <height>40</height>
                <font>SectionHeader</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>Cast</label>
            </control>

            <control type="group" id="560">
                <left>1640</left>
                <top>0</top>
                <width>120</width>
                <height>40</height>
                <include content="ButtonText">
                    <param name="ControlId" value="560" />
                    <param name="Label" value="See All" />
                    <param name="Action" value="ActivateWindow(Videos)" />
                    <param name="Width" value="120" />
                </include>
            </control>

            <control type="panel" id="500">
                <left>0</left>
                <top>56</top>
                <width>1760</width>
                <height>154</height>
                <orientation>horizontal</orientation>
                <scrolltime tween="sine">250</scrolltime>
                <itemgap>20</itemgap>
                <content>plugin://plugin.video.themoviedb.helper/?info=cast&amp;tmdb_id=$INFO[ListItem.UniqueId(tmdb)]&amp;mediatype=movie</content>
                <itemlayout width="120" height="154">
                    <include>CastCard</include>
                </itemlayout>
                <focusedlayout width="120" height="154">
                    <control type="group">
                        <width>120</width>
                        <height>154</height>
                        <animation effect="zoom" start="100" end="105" time="200" tween="sine">Focus</animation>
                        <animation effect="zoom" start="105" end="100" time="150" tween="sine">UnFocus</animation>
                        <include>CastCard</include>
                    </control>
                </focusedlayout>
            </control>

            <control type="label">
                <left>0</left>
                <top>224</top>
                <width>340</width>
                <height>40</height>
                <font>SectionHeader</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>More Like This</label>
                <visible>Container.Content(movies)</visible>
            </control>

            <control type="group" id="561">
                <left>640</left>
                <top>224</top>
                <width>120</width>
                <height>40</height>
                <visible>Container.Content(movies)</visible>
                <include content="ButtonText">
                    <param name="ControlId" value="561" />
                    <param name="Label" value="See All" />
                    <param name="Action" value="Container.SetFocus(510)" />
                    <param name="Width" value="120" />
                </include>
            </control>

            <control type="panel" id="510">
                <left>0</left>
                <top>280</top>
                <width>1760</width>
                <height>232</height>
                <orientation>horizontal</orientation>
                <scrolltime tween="sine">250</scrolltime>
                <itemgap>16</itemgap>
                <content>plugin://plugin.video.themoviedb.helper/?info=similar_movies&amp;tmdb_id=$INFO[ListItem.UniqueId(tmdb)]</content>
                <visible>Container.Content(movies)</visible>
                <itemlayout width="140" height="232">
                    <include>PosterCard</include>
                </itemlayout>
                <focusedlayout width="140" height="232">
                    <include>PosterCard</include>
                </focusedlayout>
            </control>

            <control type="label">
                <left>920</left>
                <top>224</top>
                <width>340</width>
                <height>40</height>
                <font>SectionHeader</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <label>Trailers &amp; More</label>
                <visible>Skin.HasSetting(EnableTrailerPreview)</visible>
            </control>

            <control type="group" id="562">
                <left>1640</left>
                <top>224</top>
                <width>120</width>
                <height>40</height>
                <visible>Skin.HasSetting(EnableTrailerPreview)</visible>
                <include content="ButtonText">
                    <param name="ControlId" value="562" />
                    <param name="Label" value="See All" />
                    <param name="Action" value="Container.SetFocus(520)" />
                    <param name="Width" value="120" />
                </include>
            </control>

            <control type="panel" id="520">
                <left>920</left>
                <top>280</top>
                <width>840</width>
                <height>180</height>
                <orientation>horizontal</orientation>
                <scrolltime tween="sine">250</scrolltime>
                <itemgap>16</itemgap>
                <content>plugin://plugin.video.themoviedb.helper/?info=trakt_trailers&amp;tmdb_id=$INFO[ListItem.UniqueId(tmdb)]</content>
                <visible>Skin.HasSetting(EnableTrailerPreview)</visible>
                <itemlayout width="320" height="180">
                    <include>LandscapeCard</include>
                </itemlayout>
                <focusedlayout width="320" height="180">
                    <include>LandscapeCard</include>
                </focusedlayout>
            </control>
        </control>
        <include condition="Skin.HasSetting(DebugOverlay)">DebugOverlay</include>
    </controls>
</window>
