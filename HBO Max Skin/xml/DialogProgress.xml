<?xml version="1.0" encoding="utf-8"?>
<window>
    <defaultcontrol always="true">825</defaultcontrol>

    <controls>
        <control type="image" id="820">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="$INFO[Skin.String(ColorOverlay)]">white.png</texture>
            <aspectratio>stretch</aspectratio>
            <animation effect="fade" start="100" end="0" time="200" tween="sine">WindowClose</animation>
        </control>

        <control type="group" id="821">
            <left>660</left>
            <top>430</top>
            <width>600</width>
            <height>220</height>
            <animation effect="zoom" start="95" end="100" time="250" tween="sine">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="250" tween="sine">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="200" tween="sine">WindowClose</animation>

            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>600</width>
                <height>220</height>
                <texture border="12" colordiffuse="$INFO[Skin.String(ColorElevated)]">special://skin/media/hbomax/btn-secondary.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="label" id="822">
                <left>32</left>
                <top>32</top>
                <width>536</width>
                <height>40</height>
                <font>DialogTitle</font>
                <textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor>
                <align>center</align>
                <label>$INFO[System.ProgressDialogHeader]</label>
            </control>

            <control type="label" id="823">
                <left>32</left>
                <top>84</top>
                <width>536</width>
                <height>32</height>
                <font>DialogBody</font>
                <textcolor>$INFO[Skin.String(ColorTextSecondary)]</textcolor>
                <align>center</align>
                <label>$INFO[System.ProgressDialogMessage]</label>
            </control>

            <control type="label" id="824">
                <left>472</left>
                <top>132</top>
                <width>96</width>
                <height>24</height>
                <font>MetadataInfo</font>
                <textcolor>$INFO[Skin.String(ColorTextMuted)]</textcolor>
                <align>right</align>
                <label>$INFO[System.ProgressDialogPercentage]%</label>
            </control>

            <control type="image">
                <left>48</left>
                <top>160</top>
                <width>504</width>
                <height>6</height>
                <texture colordiffuse="$INFO[Skin.String(ColorProgressBg)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="progress" id="825">
                <left>48</left>
                <top>160</top>
                <width>504</width>
                <height>6</height>
                <info>System.ProgressDialogPercentage</info>
                <texturebg>white.png</texturebg>
                <lefttexture>white.png</lefttexture>
                <midtexture colordiffuse="$INFO[Skin.String(ColorProgressFill)]">white.png</midtexture>
                <righttexture>white.png</righttexture>
                <overlaytexture>white.png</overlaytexture>
            </control>

            <control type="group" id="826">
                <left>200</left>
                <top>180</top>
                <width>200</width>
                <height>56</height>
                <visible>System.ProgressDialogCanCanceled</visible>
                <include content="ButtonSecondary">
                    <param name="ControlId" value="826" />
                    <param name="Label" value="Cancel" />
                    <param name="Icon" value="" />
                    <param name="Action" value="System.CancelProgressDialog" />
                </include>
            </control>
        </control>
        <include condition="Skin.HasSetting(DebugOverlay)">DebugOverlay</include>
    </controls>
</window>
