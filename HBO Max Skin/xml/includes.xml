<?xml version="1.0" encoding="utf-8"?>
<includes>
    <include name="DebugOverlay">
        <control type="group">
            <left>1400</left>
            <top>20</top>
            <width>500</width>
            <height>392</height>
            <visible>Skin.HasSetting(DebugOverlay)</visible>

            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>500</width>
                <height>392</height>
                <texture colordiffuse="$INFO[Skin.String(ColorDebugBackground)]">white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <control type="label"><left>20</left><top>16</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Skin Version: $INFO[Skin.Version]</label></control>
            <control type="label"><left>20</left><top>38</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Window: $INFO[System.CurrentWindow]</label></control>
            <control type="label"><left>20</left><top>60</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Window ID: $INFO[System.CurrentWindowID]</label></control>
            <control type="label"><left>20</left><top>82</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Control Focus: $INFO[System.CurrentControl]</label></control>
            <control type="label"><left>20</left><top>104</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Container ID: $INFO[Container.NumItems] items</label></control>
            <control type="label"><left>20</left><top>126</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Content Type: $INFO[Container.Content]</label></control>
            <control type="label"><left>20</left><top>148</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>ListItem Title: $INFO[ListItem.Title]</label></control>
            <control type="label"><left>20</left><top>170</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>ListItem Art: $INFO[ListItem.Art(poster)]</label></control>
            <control type="label"><left>20</left><top>192</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Fanart: $INFO[ListItem.Art(fanart)]</label></control>
            <control type="label"><left>20</left><top>214</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>ClearLogo: $INFO[ListItem.Art(clearlogo)]</label></control>
            <control type="label"><left>20</left><top>236</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Widget Path: $INFO[Skin.String(HeroWidgetPath)]</label></control>
            <control type="label"><left>20</left><top>258</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Hero Layout: $INFO[Skin.String(HomeLayout)]</label></control>
            <control type="label"><left>20</left><top>280</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Resolution: $INFO[System.ScreenWidth]x$INFO[System.ScreenHeight]</label></control>
            <control type="label"><left>20</left><top>302</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>FPS: $INFO[System.FPS]</label></control>
            <control type="label"><left>20</left><top>324</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>CPU: $INFO[System.CPUUsage]</label></control>
            <control type="label"><left>20</left><top>346</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Memory: $INFO[System.Memory(free)]</label></control>
            <control type="label"><left>20</left><top>368</top><width>460</width><height>22</height><font>font18</font><textcolor>$INFO[Skin.String(ColorTextPrimary)]</textcolor><label>Kodi Version: $INFO[System.BuildVersion]</label></control>
        </control>
    </include>
</includes>
