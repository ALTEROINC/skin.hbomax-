<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.hbomaxdev" name="HBO Max Skin Dev Repository" version="1.0.0" provider-name="Michael Hernandez">
  <requires>
    <import addon="xbmc.addon" version="12.0.0" />
  </requires>

  <extension point="xbmc.addon.repository" name="HBO Max Skin Dev Repository">
    <dir>
      <info compressed="false">https://alteroinc.github.io/skin.hbomax-/addons.xml</info>
      <checksum>https://alteroinc.github.io/skin.hbomax-/addons.xml.md5</checksum>
      <datadir zip="true">https://alteroinc.github.io/skin.hbomax-/</datadir>
    </dir>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Update channel for the HBO Max Skin Dev addon.</summary>
    <description lang="en_GB">Install this once to let Kodi automatically detect and install new versions of the HBO Max Skin Dev skin from its GitHub Pages update feed.</description>
    <platform>all</platform>
    <license>All rights reserved</license>
  </extension>
</addon>
