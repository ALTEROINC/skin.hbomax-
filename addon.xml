<?xml version="1.0" encoding="utf-8"?>
<addon id="skin.hbomax" version="1.0.0" name="HBO Max" provider-name="YOURNAME">
  <requires>
    <import addon="xbmc.gui" version="5.17.0"/>
    <import addon="script.skinshortcuts" version="1.0.0"/>
    <import addon="plugin.video.themoviedb.helper" version="1.0.0"/>
    <import addon="resource.images.studios.coloured" version="0.0.1"/>
  </requires>
  <extension point="xbmc.gui.skin" debugging="false">
    <res width="1920" height="1080" aspect="16:9" default="true" folder="xml"/>
    <res width="1920" height="1200" aspect="16:10" default="false" folder="xml"/>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">HBO Max style skin for Kodi Omega</summary>
    <description lang="en_GB">A custom Kodi skin replicating the HBO Max interface.</description>
    <platform>all</platform>
    <license>GPL v2.0</license>
    <reuselanguageinvoker>false</reuselanguageinvoker>
  </extension>
</addon>
