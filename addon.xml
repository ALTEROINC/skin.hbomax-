<?xml version="1.0" encoding="utf-8"?>
<addon id="skin.hbomax" version="1.0.0" name="HBO Max" provider-name="Michael Hernandez">
    <requires>
        <import addon="xbmc.gui" version="5.17.0" />
        <import addon="script.skinshortcuts" version="1.0.0" />
        <import addon="script.skin.helper.service" version="1.30.0" />
        <import addon="script.skin.helper.widgets" version="1.30.0" />
        <import addon="script.skin.helper.backgrounds" version="1.0.36" />
        <import addon="plugin.video.themoviedb.helper" version="5.2.12" />
        <import addon="resource.images.studios.coloured" version="0.0.23" />
    </requires>
    <!--
        Inter font files must be present in fonts/ before the skin will load.
        These font files are not included in the repository and must be added manually.
    -->
    <extension point="xbmc.gui.skin" debugging="false">
        <res width="1920" height="1080" aspect="16:9" default="true" folder="xml" />
        <res width="1920" height="1200" aspect="16:10" default="false" folder="xml" />
    </extension>
</addon>
